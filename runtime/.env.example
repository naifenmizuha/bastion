# Required trusted principal for derived-memory isolation.
BASTION_AUTHORITY_ID=local-bastion
BASTION_TEAM_ID=athletes
BASTION_USER_ID=naifen
BASTION_USER_ROLE=admin

# Optional business link for a player account. This is not an authentication ID.
# BASTION_PLAYER_ID=player-123

# Optional authoritative team database path.
# BASTION_DB_PATH=../bastion.db

# Optional per-turn task routing. Configure all four fields or leave all unset.
BASTION_SIMPLE_MODEL_PROVIDER=deepseek
BASTION_SIMPLE_MODEL_ID=deepseek-v4-flash
BASTION_COMPLEX_MODEL_PROVIDER=deepseek
BASTION_COMPLEX_MODEL_ID=deepseek-v4-pro
